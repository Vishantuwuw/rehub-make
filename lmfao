local f1,f2=Vector3.new(-372.33,-7.01,94.31),Vector3.new(-368.43,-7.01,24.36)
local pos=f1
local TP=false
local ExecuteCommand=nil

task.spawn(function()
	while not ExecuteCommand do
		pcall(function()
			local p=RS:WaitForChild("Packages",3)
			if not p then return end
			local n=p:WaitForChild("Net",3)
			if not n then return end
			local r=n:FindFirstChild("RE/AdminPanelService/ExecuteCommand",true)
			if r then ExecuteCommand=r end
		end)
		task.wait(1)
	end
end)

